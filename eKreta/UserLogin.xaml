<Window
    x:Class="eKreta.UserLogin"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:eKreta"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="UserLogin"
    Width="300"
    Height="450"
    FontSize="20"
    WindowStartupLocation="CenterScreen"
    mc:Ignorable="d">
    <StackPanel Margin="20">
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            FontSize="25"
            FontWeight="Bold"
            Text="eKréta bejelentkezés" />
        <Grid VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Left"
                Text="Felhasználónév" />
            <TextBox
                x:Name="loginUserTxt"
                Grid.Row="1"
                Width="250"
                HorizontalAlignment="Left" />
            <TextBlock
                Grid.Row="2"
                HorizontalAlignment="Left"
                Text="Jelszó" />
            <PasswordBox
                x:Name="loginPassTxt"
                Grid.Row="3"
                Width="250"
                HorizontalAlignment="Left" />
        </Grid>
        <TextBlock
            HorizontalAlignment="Right"
            FontSize="15"
            FontStyle="Italic"
            Foreground="CadetBlue"
            Text="Elfelejtett jelszó" />
        <Button
            x:Name="loginBtn"
            Width="250"
            Height="35"
            Margin="0,50,0,0"
            HorizontalAlignment="Center"
            Background="Black"
            Click="loginBtn_Click"
            Content="Bejelentkezés"
            FontSize="18"
            FontWeight="Bold"
            Foreground="White" />
    </StackPanel>
</Window>
